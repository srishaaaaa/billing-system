# Copy this file to .env for local development.
# On Vercel, set these same values as Project Environment Variables instead
# (Project Settings -> Environment Variables) — Vercel does not read .env files.

PORT=4000

# Postgres connection string. Locally you can point this at any Postgres
# database; on Vercel, install a Postgres integration (Neon is recommended)
# from the Marketplace and it will inject this automatically.
DATABASE_URL=postgres://user:password@host/dbname

# Two separate sign-in passwords, one per role.
# Staff can only access the Billing Panel.
# Admin can access Billing Panel, Order History, and Analytics Dashboard.
STAFF_PASSWORD=Staff@123
ADMIN_PASSWORD=Admin@123

# Secret used to sign login session tokens. Change this to a long random string.
JWT_SECRET=change_this_to_a_long_random_string

# Shop branding — shown in the header, login screen, and footer.
SHOP_NAME=11:11 Men's Wear & Sport's Wear
OWNER_NAME=VITHYABATHI
SHOP_ADDRESS=AGS Complex, Near Aavin Palagam, Amarakundhi.
FOOTER_TAGLINE=TAILORED. TIMELESS. CRAFTED.
POWERED_BY_NAME=CENEXA SYSTEMS
POWERED_BY_URL=https://www.cenexasystems.com/
